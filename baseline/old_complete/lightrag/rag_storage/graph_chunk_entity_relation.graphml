    <node id="Celtics">
      <data key="d0">Celtics</data>
      <data key="d1">organization</data>
      <data key="d2">The Celtics is a professional basketball team in the NBA, for which L. Kornet plays.&lt;SEP&gt;The Celtics is a professional basketball team and the user's favorite team.</data>
